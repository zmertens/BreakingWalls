-- tile_exit.script – animates the exit tile with a pulsing scale
local SPEED = 2.0
local MIN_S = 0.9
local MAX_S = 1.1

function init(self)
    self.t = 0
end

function update(self, dt)
    self.t = self.t + dt * SPEED
    local s = MIN_S + (MAX_S - MIN_S) * (0.5 + 0.5 * math.sin(self.t))
    go.set_scale(vmath.vector3(s, s, 1))
end
